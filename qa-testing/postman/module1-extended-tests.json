        {
            "name": "5. JWT Token Tests",
            "item": [
                {
                    "name": "5.1 Token Structure Validation",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 200', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test('Token is valid JWT format', function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    var token = jsonData.token;",
                                    "    var parts = token.split('.');",
                                    "    pm.expect(parts).to.have.length(3);",
                                    "",
                                    "    // Decode header",
                                    "    var header = JSON.parse(atob(parts[0]));",
                                    "    pm.expect(header).to.have.property('alg');",
                                    "    pm.expect(header).to.have.property('typ');",
                                    "    pm.expect(header.typ).to.equal('JWT');",
                                    "});",
                                    "",
                                    "pm.test('Token payload contains required claims', function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    var token = jsonData.token;",
                                    "    var parts = token.split('.');",
                                    "    var payload = JSON.parse(atob(parts[1]));",
                                    "",
                                    "    pm.expect(payload).to.have.property('sub');",
                                    "    pm.expect(payload).to.have.property('exp');",
                                    "    pm.expect(payload).to.have.property('iat');",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"{{adminEmail}}\",\n    \"password\": \"{{testPassword}}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "login"
                            ]
                        }
                    }
                },
                {
                    "name": "5.2 Token Expiration Check",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Token expiration is in the future', function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    var token = jsonData.token;",
                                    "    var parts = token.split('.');",
                                    "    var payload = JSON.parse(atob(parts[1]));",
                                    "",
                                    "    var expTime = payload.exp * 1000; // Convert to milliseconds",
                                    "    var currentTime = Date.now();",
                                    "",
                                    "    pm.expect(expTime).to.be.above(currentTime);",
                                    "});",
                                    "",
                                    "pm.test('Token has reasonable expiration (1-24 hours)', function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    var token = jsonData.token;",
                                    "    var parts = token.split('.');",
                                    "    var payload = JSON.parse(atob(parts[1]));",
                                    "",
                                    "    var expTime = payload.exp * 1000;",
                                    "    var iatTime = payload.iat * 1000;",
                                    "    var validity = expTime - iatTime;",
                                    "",
                                    "    // Token should be valid for at least 1 hour and at most 24 hours",
                                    "    pm.expect(validity).to.be.above(3600000);  // 1 hour",
                                    "    pm.expect(validity).to.be.below(86400000); // 24 hours",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"{{adminEmail}}\",\n    \"password\": \"{{testPassword}}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "login"
                            ]
                        }
                    }
                }
            ]
        },
